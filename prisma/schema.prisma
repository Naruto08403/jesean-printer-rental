generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum PrinterType {
  RENTAL
  WALK_IN
}

enum PrinterStatus {
  AVAILABLE
  RENTED
  IN_REPAIR
  RETIRED
  CLIENT_PERSONAL
}

enum RentalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum RentalAuditAction {
  CREATED
  STATUS_CHANGED
  PAUSED
  RESUMED
  RETURNED
  NOTE
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentSchedule {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum AuditAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  RENTAL_LINKED
  REPAIR_LINKED
  NOTE
}

enum ClientStatus {
  ACTIVE
  STOPPED
}

enum RepairPrinterSource {
  INVENTORY
  RENTAL
  WALK_IN
  HISTORY
}

enum RepairPricingMode {
  CATALOG
  GENERAL
}

model RepairDiagnosisOption {
  id        String   @id @default(cuid())
  name      String   @unique
  price     Float    @default(0)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String?  @unique
  passwordHash String
  name         String?
  role         UserRole @default(CLIENT)
  client       Client?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id        String             @id @default(cuid())
  name      String
  status    ClientStatus       @default(ACTIVE)
  email     String?
  phone     String?
  address   String?
  company   String?
  notes     String?
  userId    String?            @unique
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  rentals   Rental[]
  repairs   Repair[]
  sales     Sale[]
  cctvJobs  CctvInstallation[]
  ownedPrinters Printer[] @relation("PrinterOwner")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Printer {
  id             String            @id @default(cuid())
  serialNumber   String?           @unique
  brand          String?
  model          String?
  price          Float?
  type           PrinterType       @default(RENTAL)
  ownerClientId  String?
  ownerClient    Client?           @relation("PrinterOwner", fields: [ownerClientId], references: [id], onDelete: SetNull)
  status         PrinterStatus     @default(AVAILABLE)
  notes          String?
  rentals        Rental[]
  repairs        Repair[]
  auditLogs      PrinterAuditLog[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([type])
  @@index([ownerClientId])
}

model PrinterAuditLog {
  id        String      @id @default(cuid())
  printerId String
  printer   Printer     @relation(fields: [printerId], references: [id], onDelete: Cascade)
  action    AuditAction
  message   String
  metadata  String?
  userEmail String?
  createdAt DateTime    @default(now())
}

model Rental {
  id              String          @id @default(cuid())
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  printerId       String?
  printer         Printer?        @relation(fields: [printerId], references: [id], onDelete: SetNull)
  status          RentalStatus    @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime?
  ratePerPeriod   Float
  paymentSchedule PaymentSchedule @default(QUARTERLY)
  totalContract   Float?
  description     String?
  payments        Payment[]
  auditLogs       RentalAuditLog[]
  pausePeriods    RentalPausePeriod[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model RentalPausePeriod {
  id        String   @id @default(cuid())
  rentalId  String
  rental    Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  pausedAt  DateTime
  resumedAt DateTime?
  createdAt DateTime @default(now())
}

model RentalAuditLog {
  id        String            @id @default(cuid())
  rentalId  String
  rental    Rental            @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  action    RentalAuditAction
  message   String
  metadata  String?
  userEmail String?
  createdAt DateTime          @default(now())
}

model Repair {
  id                 String              @id @default(cuid())
  clientId           String?
  client             Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerName       String?
  printerId          String?
  printer            Printer?            @relation(fields: [printerId], references: [id], onDelete: SetNull)
  source             RepairPrinterSource @default(WALK_IN)
  linkedFromRepairId String?
  linkedFromRepair   Repair?             @relation("RepairDeviceHistory", fields: [linkedFromRepairId], references: [id], onDelete: SetNull)
  followUpRepairs    Repair[]            @relation("RepairDeviceHistory")
  brand              String?
  model              String?
  serialNumber       String?
  problem            String              @default("")
  diagnosis          String?
  pricingMode        RepairPricingMode   @default(CATALOG)
  status             ServiceStatus       @default(PENDING)
  totalAmount        Float               @default(0)
  isChargeWaived     Boolean             @default(false)
  receivedAt         DateTime            @default(now())
  completedAt        DateTime?
  title              String?
  description        String?
  billingDate        DateTime?
  payments           Payment[]
  diagnosisLines     RepairDiagnosisLine[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([serialNumber])
  @@index([printerId])
  @@index([clientId])
}

model RepairDiagnosisLine {
  id        String @id @default(cuid())
  repairId  String
  repair    Repair @relation(fields: [repairId], references: [id], onDelete: Cascade)
  name      String
  price     Float  @default(0)
  sortOrder Int    @default(0)

  @@index([repairId])
}

model Sale {
  id          String        @id @default(cuid())
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status      ServiceStatus @default(COMPLETED)
  items       String
  totalAmount Float
  notes       String?
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CctvInstallation {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      ServiceStatus @default(PENDING)
  siteAddress String?
  description String?
  totalAmount Float
  completedAt DateTime?
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Payment {
  id                 String            @id @default(cuid())
  amount             Float
  paidAt             DateTime          @default(now())
  /** Billing period (0–11) for rental monthly grid — authoritative vs paidAt timezone. */
  billingYear        Int?
  billingMonth       Int?
  /** All rows from one Add payment submit share a batch id. */
  batchId            String?
  method             String?
  reference          String?
  notes              String?
  rentalId           String?
  rental             Rental?           @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  repairId           String?
  repair             Repair?           @relation(fields: [repairId], references: [id], onDelete: Cascade)
  saleId             String?
  sale               Sale?             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  cctvInstallationId String?
  cctvInstallation   CctvInstallation? @relation(fields: [cctvInstallationId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now())

  @@index([batchId])
  @@index([billingYear, billingMonth])
}

model PrinterBrand {
  id        String @id @default(cuid())
  name      String @unique

  models    PrinterModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrinterModel {
  id        String @id @default(cuid())

  brandId   String
  brand     PrinterBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  name      String

  pricings  RepairPricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brandId, name])
}

model RepairPricing {
  id              String @id @default(cuid())

  printerModelId  String?
  printerModel    PrinterModel? @relation(fields: [printerModelId], references: [id], onDelete: Cascade)

  repairName      String

  laborCost       Float
  partsCost       Float

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([printerModelId])
}